# Copy this file to .env and fill in the values before running docker compose.

# Redis password (leave blank for no authentication in local dev)
REDIS_PASSWORD=

# Redis URL seen by the backend container.
# When using the local redis container with no password:
#   REDIS_URL=redis://redis:6379
# With a password:
#   REDIS_URL=redis://:yourpassword@redis:6379
REDIS_URL=redis://redis:6379

# OpenAI key used by the LangGraph agent
OPENAI_API_KEY=

# URL the React frontend uses to reach the backend.
# In local dev this is the host machine's port 8000.
REACT_APP_API_URL=http://localhost:8000
