// Team A and Team B
#define A 1;
#define B 2;
#define Awin Ascore > Bscore && t > gametime;
#define gametime 90;

// Ar refers to pass reliability of team A when the team posesses the ball without B's pressure
// Ap refers to pressure degree when team B possesses the ball
// vice versa for Br and Bp
// these values are intended to be the parameter chosen by AI agent
// either by pulling from extracted data prepared or choosing appropriate value to answer user's question based on predicate
#define Ar 1;
#define Ap 1;
#define Br 1;
#define Bp 1;
#define timespeed 10;

//arbitrary constant multiplier that decides negative effect of opponent's pressure
var a = 1/5;
// pass reliability of team A
var ApassR = Ar- a*Bp;
// pass reliability of team B
var BpassR = Br - a*Ap;
var t = 0;

// 0 means nobody has it, 1 and 2 are team A and B possessing respectively
var ball:{0..2} = 0;
var Ascore = 0;
var Bscore = 0;

// reflects the initial coin toss in game deciding kickoff
Game()= pcase{
  [0.5]:kickoff.(A) -> Play(A)
  [0.5]:kickoff.(B) -> Play(B)
};

// assuming by 20% of chance that a team can score while possessing the ball
// model to be further modified to be close to reality in future
Play(i) = if (i == A) {
  pcase{
    ApassR*4/5: pass.i{t = t + timespeed} -> Play(i)
    ApassR/5: goal.i{Ascore ++; t = t + timespeed} -> Game()
    1- ApassR: Play(3-i)
  }
} else if (i == B){
  pcase {
    BpassR*4/5: pass.i{t = t + timespeed} -> Play(i)
    BpassR/5: goal.i{Bscore ++; t = t + timespeed} -> Game()
    1-BpassR: Play(3-i)
  }
} else {
  pcase{
    [0.5]:contesting{t = t + timespeed} -> Play(A)
    [0.5]:contesting{t = t + timespeed} -> Play(B)
  }

};

#assert Game() deadlockfree;
#assert Game() reaches Awin with pmin;
